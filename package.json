{
  "name": "sequences-openai-build-week",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@hyperframes/core": "0.7.56",
    "@hyperframes/engine": "0.7.56",
    "@hyperframes/lint": "0.7.56",
    "@hyperframes/parsers": "0.7.56",
    "@hyperframes/player": "0.7.56",
    "@hyperframes/producer": "0.7.56",
    "@hyperframes/sdk": "0.7.56",
    "@hyperframes/shader-transitions": "0.7.56",
    "@hyperframes/studio": "0.7.56",
    "@hyperframes/studio-server": "0.7.56"
  },
  "scripts": {
    "bootstrap": "bun scripts/bootstrap.ts",
    "dev": "bun run bootstrap && bun run build && concurrently --kill-others-on-fail --names server,web,studio --prefix-colors blue,green,magenta \"bun run dev:server\" \"bun run dev:client\" \"bun run dev:studio\"",
    "dev:server": "bun --watch apps/web/src/server/index.ts",
    "dev:client": "vite build --watch --config apps/web/vite.config.ts",
    "dev:studio": "bun scripts/hyperframes.ts preview data/projects/release-a --port 5190 --no-open --force-new",
    "build": "vite build --config apps/web/vite.config.ts",
    "start": "bun apps/web/src/server/index.ts",
    "studio": "bun scripts/hyperframes.ts preview data/projects/release-a --port 5190 --no-open --force-new",
    "judge": "bun run bootstrap && bun run doctor && bun run build && concurrently --kill-others-on-fail --names app,studio \"bun run start\" \"bun run studio\"",
    "doctor": "bun scripts/doctor.ts",
    "hf": "bun scripts/hyperframes.ts",
    "lint": "oxlint apps scripts",
    "format": "oxfmt apps scripts *.json *.md",
    "format:check": "oxfmt --check apps scripts *.json *.md",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "qa:fixture": "bun run bootstrap && bun scripts/hyperframes.ts lint fixtures/release-a --json && bun scripts/hyperframes.ts check fixtures/release-a --json --strict --snapshots --at-transitions --frame-check",
    "render:fixture": "bun run bootstrap && bun scripts/hyperframes.ts render fixtures/release-a --quality draft --workers 1 --output artifacts/release-a-draft.mp4",
    "test:security": "vitest run --config vitest.config.ts apps/web/test/server/security.test.ts",
    "test:replay": "vitest run --config vitest.config.ts apps/web/test/server/replay.test.ts"
  },
  "dependencies": {
    "@hyperframes/core": "0.7.56",
    "@hyperframes/engine": "0.7.56",
    "@hyperframes/lint": "0.7.56",
    "@hyperframes/parsers": "0.7.56",
    "@hyperframes/player": "0.7.56",
    "@hyperframes/producer": "0.7.56",
    "@hyperframes/sdk": "0.7.56",
    "@hyperframes/shader-transitions": "0.7.56",
    "@hyperframes/studio-server": "0.7.56",
    "@phosphor-icons/react": "2.1.10",
    "gsap": "3.13.0",
    "hono": "4.12.30",
    "hyperframes": "0.7.56",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
