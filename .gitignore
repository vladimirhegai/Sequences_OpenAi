bun.lockb
.env
.env.*
!.env.example

# Build and test output.
apps/web/dist/
coverage/
test-results/
*.tsbuildinfo
.vite/

# Local runtime state and generated delivery output, including every run and
# render receipt. These diagnosis packets stay on the operator's machine.
artifacts/
data/
renders/
workbench/

# Local working summaries and superseded diagnostic snapshots are not part of
# the judge-facing source tree.
SUMMARY.md
demos/**/snapshots/finding-*
Showcase/**/snapshots/finding-*
Showcase/**/snapshots/**/finding-*
Showcase/**/check-snapshots-history/finding-*

# These five final Showcase renders are public product assets. Keep other
# generated and superseded renders ignored.
!Showcase/**/renders/
Showcase/**/renders/**
!Showcase/chatgpt-ad/renders/final.mp4
!Showcase/chatgpt-native-story/renders/final.mp4
!Showcase/sequences-abstract-ad/renders/sequences-abstract-ad.mp4
!Showcase/sequences-recommendation-ad/renders/sequences-recommendation-ad-final.mp4
!Showcase/slack-ad/renders/final.mp4

# Local creative inputs and superseded showcase renders are not source assets.
Video References/
Showcase/**/archive/

# Fixture-local generated output. Bundled vendor runtimes are intentionally
# committed because the offline fixtures and doctor check require them.
fixtures/**/renders/
fixtures/**/snapshots/
fixtures/**/.hyperframes/

# Logs, temporary files, and common editor/OS metadata.
debug.log
*.log
*.tmp
.DS_Store
Thumbs.db
