# Local-only port. The authenticated shell and backend share this exact origin.
SEQUENCES_PORT=4317

# Optional executable override. The default is `codex` on PATH.
SEQUENCES_CODEX_COMMAND=codex

# Native Windows always uses danger-full-access because workspace-write can
# silently resolve read-only there. This is a local-only compatibility choice;
# Sequences accepts only an allowlisted diff from a disposable candidate.
# Non-Windows defaults to workspace-write and may override it explicitly.
# SEQUENCES_CODEX_SANDBOX=workspace-write

# Author model routing. The default director is GPT-5.6 Luna at high reasoning.
# Overrides exist for controlled A/B probes (for example gpt-5.6-sol or
# gpt-5.6-terra); the run receipt records the model actually used.
# SEQUENCES_CODEX_MODEL=gpt-5.6-luna
# SEQUENCES_CODEX_EFFORT=high

# Balanced is the production default. One Sol preproduction turn locks design,
# story, and the component plan; Terra composes; deterministic QA and a bounded
# read-only Sol temporal audit follow. Use legacy only for controlled comparison.
# SEQUENCES_AGENT_WORKFLOW=legacy
# SEQUENCES_CREATIVE_MODEL=gpt-5.6-sol
# SEQUENCES_CREATIVE_EFFORT=medium
# SEQUENCES_COMPONENT_MODEL=gpt-5.6-sol
# SEQUENCES_COMPONENT_EFFORT=medium
# SEQUENCES_COMPOSITOR_MODEL=gpt-5.6-terra
# SEQUENCES_COMPOSITOR_EFFORT=medium
# SEQUENCES_AUDITOR_MODEL=gpt-5.6-sol
# SEQUENCES_AUDITOR_EFFORT=medium

# The boot/session/CSRF tokens are generated in memory for every server launch.
